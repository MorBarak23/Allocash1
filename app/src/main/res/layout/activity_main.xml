<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_background"
    android:fitsSystemWindows="false">

    <ImageView
        android:id="@+id/btn_open_drawer"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_margin="25dp"
        android:src="@drawable/ic_menu"
        app:tint="@color/text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/lbl_app_name"
        android:layout_width="120dp"
        android:layout_height="25dp"
        android:background="@drawable/img_logo"
        app:layout_constraintBottom_toBottomOf="@id/btn_open_drawer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_open_drawer" />

    <ImageView
        android:id="@+id/ic_user"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_margin="22dp"
        android:src="@drawable/ic_user2"
        app:tint="@color/text_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/main_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lbl_app_name" />

</androidx.constraintlayout.widget.ConstraintLayout>